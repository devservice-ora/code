<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">
    <persistence-unit name="HRModel" transaction-type="JTA">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
        <jta-data-source>java:/app/jdbc/jdbc/hrDS</jta-data-source>
        <class>model.Country</class>
        <class>model.Department</class>
        <class>model.Employee</class>
        <class>model.Job</class>
        <class>model.JobHistory</class>
        <class>model.Location</class>
        <class>model.Region</class>
        <properties>
            <property name="eclipselink.target-server" value="WebLogic_12"/>
            <property name="javax.persistence.jtaDataSource" value="java:/app/jdbc/jdbc/hrDS"/>
            <property name="eclipselink.logging.level" value="ALL"/>
            <property name="eclipselink.logging.level.sql" value="FINE"/>
            <property name="eclipselink.logging.parameters" value="true"/>
            <property name="eclipselink.logging.logger" value="ServerLogger"/>
        </properties>
    </persistence-unit>
</persistence>
